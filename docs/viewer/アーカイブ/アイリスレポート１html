<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Letter from Iris | 甘々レビュー</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Noto+Serif+JP:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #3a2d28;
            --paper: #fffcf5;
            --gold: #b39764;
            --accent: #8ba58d; /* 春の芽吹き */
            --night-bg: #1a1614;
            --shadow: rgba(0, 0, 0, 0.2);
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--night-bg);
            margin: 0;
            font-family: 'Noto Serif JP', serif;
            color: var(--ink);
            line-height: 1.8;
            display: flex;
            justify-content: center;
            padding: 40px 20px;
        }

        /* 背景演出：春の夜 */
        .letter-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at top right, #2c2520 0%, #1a1614 100%);
            z-index: -1;
        }

        .letter-container {
            max-width: 700px;
            width: 100%;
            filter: drop-shadow(0 15px 30px var(--shadow));
            opacity: 0; /* JSでフェードイン */
            transition: opacity 1.5s ease-in;
        }

        .letter-paper {
            background-color: var(--paper);
            padding: 60px 50px;
            position: relative;
            border-radius: 2px;
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
        }

        /* 装飾枠 */
        .letter-paper::before {
            content: '';
            position: absolute;
            top: 20px; bottom: 20px; left: 20px; right: 20px;
            border: 1px solid var(--gold);
            pointer-events: none;
            opacity: 0.4;
        }

        .letter-header { margin-bottom: 40px; }
        .tea-accent { font-size: 2rem; margin-bottom: 10px; }
        .recipient-line { font-size: 1.2rem; font-weight: 700; border-bottom: 2px solid var(--gold); display: inline-block; }

        .letter-intro { margin-bottom: 30px; font-weight: 500; }
        .tea-suggestion {
            margin-top: 20px;
            padding: 15px;
            background: rgba(139, 165, 141, 0.1);
            border-left: 3px solid var(--accent);
            font-size: 0.95rem;
        }

        .letter-divider {
            border: none;
            border-top: 1px double var(--gold);
            margin: 40px 0;
        }

        .review-meta { margin-bottom: 30px; }
        .read-status { 
            font-family: 'Cinzel', serif;
            color: var(--gold);
            font-size: 0.85rem;
            letter-spacing: 1px;
        }
        .review-summary {
            font-size: 1.1rem;
            font-weight: 700;
            color: #4a3b35;
            margin-top: 10px;
        }

        .letter-body p {
            margin-bottom: 1.5em;
            text-align: justify;
        }

        .letter-footer {
            margin-top: 60px;
            text-align: right;
        }

        .closing { font-weight: 700; color: var(--gold); margin-bottom: 20px; }
        .signature {
            font-size: 1.1rem;
            font-weight: 500;
        }

        @media (max-width: 600px) {
            .letter-paper { padding: 40px 25px; }
            .recipient-line { font-size: 1.1rem; }
        }
    </style>
</head>
<body>
    <div class="letter-overlay"></div>
    
    <main class="letter-container" id="container">
        <article class="letter-paper">
            <header class="letter-header">
                <div class="tea-accent">☕✨</div>
                <p class="recipient-line"><span id="recipient"></span> 様</p>
            </header>

            <section class="letter-intro">
                <p id="intro-text"></p>
                <div class="tea-suggestion">
                    よろしければ、このあとは今の季節にぴったりな<br>
                    <strong id="tea-name"></strong> でも召し上がって、<br>
                    ゆっくりお休みくださいませ。
                </div>
            </section>

            <hr class="letter-divider">

            <section class="review-meta">
                <div class="read-status">STATUS: <span id="read-count"></span> READING COMPLETED</div>
                <div class="review-summary" id="review-summary"></div>
            </section>

            <section class="letter-body" id="letter-body">
                </section>

            <footer class="letter-footer">
                <p class="closing">引き続き応援しております・・・！</p>
                <div class="signature">
                    <span class="sign-label">ーーー</span>
                    <span id="sign-name"></span>
                    <span class="sign-label">ーーーー</span>
                </div>
            </footer>
        </article>
    </main>

    <script>
        // 確認用ダミーデータ（本来は review.json から読み込むもの）
        const reviewData = {
            "recipient": "Resetter",
            "intro": "こ、こんにちは　Resetter様！\n私メイドのアイリス・アールグレイが\nLANCERに代わって感想をお伝えしようと思います。",
            "tea_service": "春摘みのダージリン（ファーストフラッシュ）",
            "read_count": "9話",
            "summary": "暖かな春が訪れているにも関わらず、背筋が凍るようなお話でした・・・。",
            "body": [
                "お、お家賃安すぎます・・・！日本の地方都市と言えどもこれは破格です。ただ入居条件がこの作品の肝だと感じました。ツッコミどころを用意してインパクト与える面白い仕掛けだと読んでて思いました。",
                "文章自体は全体的に読みやすくて、苦に感じませんでした！流動的な物語の運び、流石作者様の力量を感じました！",
                "読んでて混乱したのは、おっさんなのに語尾というか言葉遣いや地の文が女性っぽいという点。でも設定として面白いです・・・！",
                "会話がメインで構成されていて、地の文は少なめ。意図的なのかテンポ感意識して敢えて削ってるのか読んでて気になりました。僭越ながら苦言を呈するなら、地の文を増やした方がより情景をイメージしやすい回もあるかな？と思う部分はありました。",
                "でも読んでて非常にワクワクしました！"
            ],
            "sign": "アイリス・アールグレイ"
        };

        // 描画処理
        function renderReview(data) {
            document.getElementById('recipient').textContent = data.recipient;
            document.getElementById('intro-text').innerText = data.intro;
            document.getElementById('tea-name').textContent = data.tea_service;
            document.getElementById('read-count').textContent = data.read_count;
            document.getElementById('review-summary').textContent = data.summary;
            document.getElementById('sign-name').textContent = data.sign;

            const bodyContainer = document.getElementById('letter-body');
            data.body.forEach(paragraph => {
                const p = document.createElement('p');
                p.textContent = paragraph;
                bodyContainer.appendChild(p);
            });

            // フェードイン表示
            setTimeout(() => {
                document.getElementById('container').style.opacity = "1";
            }, 100);
        }

        // 実行
        renderReview(reviewData);
    </script>
</body>
</html>