:root {
    --ink: #3a2d28;
    --paper: #fffcf5;
    --gold: #b39764;
    --accent: #8ba58d; /* 春の芽吹きイメージ */
    --night-bg: #1a1614;
    --shadow: rgba(0, 0, 0, 0.2);
}

* { box-sizing: border-box; }

body {
    background-color: var(--night-bg);
    margin: 0;
    font-family: 'Noto Serif JP', serif;
    color: var(--ink);
    line-height: 1.8;
    display: flex;
    justify-content: center;
    padding: 40px 20px;
}

/* 背景演出：春の夜 */
.letter-overlay {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle at top right, #2c2520 0%, #1a1614 100%);
    z-index: -1;
}

.letter-container {
    max-width: 700px;
    width: 100%;
    filter: drop-shadow(0 15px 30px var(--shadow));
}

.letter-paper {
    background-color: var(--paper);
    padding: 60px 50px;
    position: relative;
    border-radius: 2px;
    /* 便箋のテクスチャ（微細なざらつき） */
    background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
}

/* 装飾枠 */
.letter-paper::before {
    content: '';
    position: absolute;
    top: 20px; bottom: 20px; left: 20px; right: 20px;
    border: 1px solid var(--gold);
    pointer-events: none;
    opacity: 0.4;
}

.letter-header { margin-bottom: 40px; }
.tea-accent { font-size: 2rem; margin-bottom: 10px; }
.recipient-line { font-size: 1.2rem; font-weight: 700; border-bottom: 2px solid var(--gold); display: inline-block; }

.letter-intro { margin-bottom: 30px; font-weight: 500; }
.tea-suggestion {
    margin-top: 20px;
    padding: 15px;
    background: rgba(139, 165, 141, 0.1);
    border-left: 3px solid var(--accent);
    font-size: 0.95rem;
}

.letter-divider {
    border: none;
    border-top: 1px double var(--gold);
    margin: 40px 0;
}

.review-meta { margin-bottom: 30px; }
.read-status { 
    font-family: 'Cinzel', serif;
    color: var(--gold);
    font-size: 0.85rem;
    letter-spacing: 1px;
}
.review-summary {
    font-size: 1.1rem;
    font-weight: 700;
    color: #4a3b35;
    margin-top: 10px;
}

.letter-body p {
    margin-bottom: 1.5em;
    text-align: justify;
}

.letter-footer {
    margin-top: 60px;
    text-align: right;
}

.closing { font-weight: 700; color: var(--gold); margin-bottom: 20px; }
.signature {
    font-size: 1.1rem;
    font-weight: 500;
}

/* レスポンシブ */
@media (max-width: 600px) {
    .letter-paper { padding: 40px 25px; }
    .recipient-line { font-size: 1.1rem; }
}



document.addEventListener('DOMContentLoaded', () => {
    fetch('review.json')
        .then(response => {
            if (!response.ok) throw new Error('JSONの読み込みに失敗しました');
            return response.json();
        })
        .then(data => {
            // 基本情報の流し込み
            document.getElementById('recipient').textContent = data.recipient;
            document.getElementById('intro-text').innerText = data.intro;
            document.getElementById('tea-name').textContent = data.tea_service;
            document.getElementById('read-count').textContent = data.read_count;
            document.getElementById('review-summary').textContent = data.summary;
            document.getElementById('sign-name').textContent = data.sign;

            // 本文の段落生成
            const bodyContainer = document.getElementById('letter-body');
            data.body.forEach(paragraph => {
                const p = document.createElement('p');
                p.textContent = paragraph;
                bodyContainer.appendChild(p);
            });
            
            // フェードイン演出
            document.querySelector('.letter-paper').style.opacity = "0";
            setTimeout(() => {
                document.querySelector('.letter-paper').style.transition = "opacity 1.5s ease-in";
                document.querySelector('.letter-paper').style.opacity = "1";
            }, 100);
        })
        .catch(error => {
            console.error('Error:', error);
            document.body.innerHTML = `<p style="color:white; text-align:center;">お手紙を読み込めませんでした（${error.message}）</p>`;
        });
});